{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "formzero-email",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "formzero",
			"database_id": "1921b3bd-988b-4281-8289-d7c808cf6606",
		}
	]
}